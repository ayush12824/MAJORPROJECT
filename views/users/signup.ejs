<% layout("/layouts/boilerplate")%> <br />

<div class="row mt-3">
  <h1 class="col-6 offset-3">SignUp for wanderlust</h1>
  <div class="col-6 offset-3">
    <form method="POST" action="/signup" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">username</label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please add a username</div>
      </div>
      <div class="mb-3">
        <label for="email" class="form-label">email</label>
        <input
          name="email"
          id="email"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please add a email</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">password</label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please add a password</div>
      </div>
      <button class="btn btn-success mb-2">SignUp</button>
    </form>
  </div>
</div>
